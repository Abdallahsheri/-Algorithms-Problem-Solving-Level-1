// Problem #31 - Power Of 2, 3, 4
int ReadNumber()
{
    int Number;
    cout << "Please enter a numebr : " << endl;
    cin >> Number;
    return Number;
}
void PowerOf2_3_4(int Number)
{
    int a, b, c;
    a = Number * Number;
    b = Number * Number * Number;
    c = Number * Number * Number * Number;
    cout << a << " " << b << " " << c;
}
int main()
{   
    PowerOf2_3_4(ReadNumber());
    
